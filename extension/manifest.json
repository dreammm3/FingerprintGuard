{
  "manifest_version": 3,
  "name": "FingerprintGuard",
  "version": "0.1.0",
  "description": "FingerprintGuard research prototype bootstrap extension.",
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "injected/injected.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "permissions": [],
  "host_permissions": [
    "<all_urls>"
  ]
}
